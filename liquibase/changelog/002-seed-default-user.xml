<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="007-seed-default-user" author="andrew">
        <comment>Create default 'andrew' user for Phase 1 development</comment>

        <insert tableName="user">
            <column name="username" value="andrew"/>
            <column name="password_hash" value="$2a$10$placeholder.hash.for.phase1"/>
            <column name="role" value="author"/>
        </insert>

        <rollback>
            <delete tableName="user">
                <where>username = 'andrew'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
